# StaticBitXrplMcp service settings. Copy to .env and fill in.
#
# Note: Traefik-wide settings (LETSENCRYPT_EMAIL) live in /opt/traefik/.env
# (the platform compose project). This file only carries variables specific
# to the xrpl-mcp service.

# Public hostname for this MCP. Must already have an A-record pointing to this server.
XRPL_MCP_HOST=xrpl-mcp.staticbit.io

# Optional: override the image tag (e.g. pin to a SHA in production).
# XRPL_MCP_IMAGE=ghcr.io/staticbit-io/staticbit-xrpl-mcp:latest
