# Per-MCP secrets. Copy to .env.xrpl-mcp (gitignored) and fill in.
#
# StaticBitXrplMcp is STATELESS w.r.t. user secrets: it never accepts an XRPL
# seed or private key — all signing happens client-side. This file therefore
# only carries server-side settings: bearer tokens for client authentication,
# HTTPS enforcement, rate limiting, and optional XRPL endpoint overrides.

# ── Transport ────────────────────────────────────────────────────────────────
Server__Transport=http
Server__HttpPort=5500

# ── Bearer authentication ───────────────────────────────────────────────────
# Multiple bearer tokens, one per consumer (you, a teammate, a routine, etc.).
# Each must be >= 32 chars. Generate with:  openssl rand -base64 48 | tr '/+' '_-'
# The Label appears in structured logs so you can audit which client did what.
Server__HttpAuth__Tokens__0__Token=CHANGE_ME_GENERATE_A_LONG_RANDOM_TOKEN_FOR_OWNER
Server__HttpAuth__Tokens__0__Label=owner

# Add more entries by incrementing the index:
# Server__HttpAuth__Tokens__1__Token=CHANGE_ME_TOKEN_FOR_ALICE
# Server__HttpAuth__Tokens__1__Label=alice
# Server__HttpAuth__Tokens__2__Token=CHANGE_ME_TOKEN_FOR_BOB
# Server__HttpAuth__Tokens__2__Label=bob

# Traefik terminates TLS and passes X-Forwarded-Proto=https to this container,
# so keep RequireHttps=true even though the container itself receives plain HTTP.
Server__HttpAuth__RequireHttps=true

# ── Rate limit ──────────────────────────────────────────────────────────────
# Fixed-window per client IP (resolved from X-Forwarded-For).
Server__RateLimit__Enabled=true
Server__RateLimit__PermitsPerMinute=60

# ── XRPL settings ───────────────────────────────────────────────────────────
StaticBitXrplMcp__DefaultNetwork=mainnet
StaticBitXrplMcp__RequestTimeoutSeconds=30
StaticBitXrplMcp__LastLedgerSequenceOffset=20

# Optional: override XRPL node WebSocket URLs (defaults shown below).
# StaticBitXrplMcp__Networks__mainnet=wss://xrplcluster.com
# StaticBitXrplMcp__Networks__testnet=wss://s.altnet.rippletest.net:51233
# StaticBitXrplMcp__Networks__devnet=wss://s.devnet.rippletest.net:51233

# ── Admin alerts (optional) ─────────────────────────────────────────────────
# When enabled, the server posts operational events (auth failures, rate-limit
# hits, lifecycle) to a dedicated Telegram chat via a SEPARATE bot — isolated
# from anything else running on the host. Off by default.
#
# To enable:
#   1. @BotFather → /newbot → make a server-admin bot (NOT shared with anything else).
#   2. Create a private chat or use @userinfobot to get your own chat_id.
#   3. Add the admin bot to that chat as admin.
#   4. Set the three variables below and `docker compose up -d`.

Server__AdminAlerts__Enabled=false
# Server__AdminAlerts__BotToken=123456:CHANGE_ME
# Server__AdminAlerts__ChatId=-1001234567890

# Per-event toggles (all default true once Enabled=true):
# Server__AdminAlerts__Events__AuthFailure=true
# Server__AdminAlerts__Events__RateLimit=true
# Server__AdminAlerts__Events__ToolError=true
# Server__AdminAlerts__Events__Lifecycle=true

# Throttling — dedup within window, hard cap per minute, bounded queue.
# Server__AdminAlerts__Throttling__DedupWindowMinutes=5
# Server__AdminAlerts__Throttling__MaxAlertsPerMinute=10
# Server__AdminAlerts__Throttling__QueueCapacity=1000

# ── Logging ─────────────────────────────────────────────────────────────────
# Trace | Debug | Information | Warning | Error | Critical | None
Logging__LogLevel__Default=Information
